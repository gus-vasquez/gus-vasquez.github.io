# Copy to `.env.development` / `.env.production` (or export before `gatsby build`).
# Values come from Firebase Console → Project settings → Your apps → Web app config.
# Enable: Authentication → Sign-in method → Anonymous; Cloud Firestore; deploy rules from `firestore.rules` (see `firebase.json`).

GATSBY_FIREBASE_API_KEY=
GATSBY_FIREBASE_AUTH_DOMAIN=
GATSBY_FIREBASE_PROJECT_ID=
GATSBY_FIREBASE_STORAGE_BUCKET=
GATSBY_FIREBASE_MESSAGING_SENDER_ID=
GATSBY_FIREBASE_APP_ID=
